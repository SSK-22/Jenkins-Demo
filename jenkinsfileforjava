pipeline {
    agent any

    stages {

        stage('Clone Code') {
            steps {
                git branch: 'main',
                url: 'https://github.com/SSK-22/Jenkins-Demo.git'
            }
        }

        stage('Compile Code') {
            steps {
                bat 'javac Test1.java Test2.java Test3.java'
            }
        }

        stage('Run Code') {
            steps {
                bat 'java Test1'
bat 'java Test2'
bat 'java Test3'
            }
        }
    }
}
