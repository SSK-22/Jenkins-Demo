pipeline {
    agent any

    stages {

        stage('Clone Code') {
            steps {
                git branch: 'main',
                url: 'https://github.com/SSK-22/Jenkins-Demo.git'
            }
        }

        stage('Compile Code') {
            steps {
                bat 'javac demo.java'
            }
        }

        stage('Run Code') {
            steps {
                bat 'java demo'
            }
        }
    }
}
